# Agent Geronimo Environment Variables
# Copy this to .env and fill in values

# SAM.gov API Key (free: https://api.sam.gov/prod/sgs/v1/search/?api_key=DEMO_KEY)
SAM_GOV_API_KEY=DEMO_KEY

# Grants.gov API (no key needed for search, but register for higher limits)
# https://www.grants.gov/web/grants/s2s/applicant/applicant-system-to-system.html
GRANTS_GOV_API_KEY=

# Optional: USASPENDING API (public, no key needed)
# Optional: Google Custom Search API (for broader web search)
GOOGLE_API_KEY=
GOOGLE_CSE_ID=

# Output directory (default: ~/agent-geronimo/output/)
OUTPUT_DIR=

# TSM local files path
TSM_LOCAL_PATH=~/Desktop/TSM!!!

# Cache TTL in hours (default: 24)
CACHE_TTL_HOURS=24

# Max concurrent requests
MAX_CONCURRENT=5

# Log level
LOG_LEVEL=INFO
